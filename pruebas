    // Function to strictly validate and normalize HH:MM format  
    const regex = /^(0[0-9]|1[0-9]|2[0-3]):([0-5][0-9])$/;  
    if (!regex.test(value)) {  
        return ''; // Invalid time format  
    }  
    return value;  
}  

